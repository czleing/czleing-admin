############## 通用环境配置，字段名必须以 VITE_APP_ 开头 ################
############## 默认 import.meta.env 自带的属性如下： ################
############## DEV: 是否开发环境
############## PORD: 是否正式环境
############## BASE_URL: 页面上下文路径/根路径
############## MODE: 环境名称
############## SSR: 是否服务端渲染

# 高德地图定位相关
# 高德地图key
VITE_APP_GD_MAP_KEY = 'xxx'
# 高德地图密钥
VITE_APP_GD_MAP_SECRET = 'xxx'